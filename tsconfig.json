{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "node",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "outDir": "./dist",
    "rootDir": "./",
    "sourceMap": true
  },
  "include": [
    "tests/**/*",
    "utils/**/*",
    "scripts/**/*",
    "playwright.config.ts"
, "types/autodoc.types.ts", "types/markdown-test-parser.types.ts"  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.js"
  ]
}